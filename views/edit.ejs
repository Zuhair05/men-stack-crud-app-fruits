<%- include('./partials/nav') %>
    <h1>Edit <%= foundFruit.name %></h1>
    <form action="/fruits/<%= foundFruit.id %>?_method=PUT" method="POST">
        <label for="name">Name:</label>
        <input type="text" id="name" name="name" value="<%= foundFruit.name %>" >
        <br>
        <div class="checkbox-div">
            <label for="isReadyToEat">Is Ready to Eat?</label>
            <input type="checkbox" id="isReadyToEat" name="isReadyToEat" <%= foundFruit.isReadyToEat ? 'checked' : '' %>>
        </div>
        <br>
        <button type="submit">Update Fruit</button>
    </form>
</body>
</html>